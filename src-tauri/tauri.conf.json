{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rsiew",
  "version": "0.1.5",
  "identifier": "com.Yoake.rsiew",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "cli": {
      "description": "rsiew CLI",
      "subcommands": {
        "stats": {
          "description": "Query work dynamics statistics",
          "args": [
            {
              "name": "range",
              "description": "Time range: today, week, or custom timestamps",
              "index": 1
            },
            {
              "name": "start",
              "short": "s",
              "description": "Custom start timestamp (Unix seconds)",
              "takesValue": true
            },
            {
              "name": "end",
              "short": "e",
              "description": "Custom end timestamp (Unix seconds)",
              "takesValue": true
            }
          ]
        },
        "uninstall-cleanup": {
          "description": "Hidden command for PATH cleanup during uninstall",
          "args": []
        }
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "rsiew",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installerHooks": "build/nsis/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}